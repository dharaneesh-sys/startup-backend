DATABASE_URL=postgresql+asyncpg://mechoncall:mechoncall@localhost:5432/mechoncall
SYNC_DATABASE_URL=postgresql://mechoncall:mechoncall@localhost:5432/mechoncall
REDIS_URL=redis://localhost:6379/0

JWT_SECRET_KEY=replace-with-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=10080

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Local demos: auto-verify mechanics/garages so matching finds providers immediately
DEV_AUTO_VERIFY_PROVIDERS=true

# Optional OAuth (set both for strict audience checks)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

UPLOAD_DIR=uploads
MAX_UPLOAD_MB=10
